{
  "name": "Lucid Lyrics",
  "version": "1.0.17",
  "private": true,
  "description": "A Powerful Lyrics Extension",
  "author": "Sanooj E Sanish <mail@sanooj.uk>",
  "workspaces": [
    "packages/arabic-transliteration",
    "packages/armenian-transliteration",
    "packages/hebrew-transliteration",
    "packages/gothic-transliteration",
    "packages/persian-transliteration",
    "packages/urdu-transliteration"
  ],
  "type": "module",
  "scripts": {
    "sc": "bun --bun run spicetify-creator",
    "dev": "bun run build:packages && bun --bun run spicetify-creator dev",
    "build:theme": "bun run build:packages && bun --bun run spicetify-creator build",
    "build": "bun run docs:build && bun run build:theme",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "clean:spice": "spicetify-creator clean-spicetify --all",
    "build:packages": "bun --filter './packages/*' build",
    "update:packages": "bun run build:packages && bun scripts/update-packages.ts",
    "generate-release-artifacts": "bun run scripts/generate-release-artifacts.ts",
    "generate-links": "bun scripts/generate-jsdelivr-links.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@darkroom.engineering/tempus": "^0.0.46",
    "@fastify/deepmerge": "^3.2.1",
    "@nanostores/persistent": "^1.3.3",
    "@nanostores/query": "^0.3.4",
    "@nanostores/solid": "^1.1.1",
    "@solid-primitives/i18n": "^2.2.1",
    "aromanize": "^0.1.5",
    "esbuild-plugin-glsl": "^1.4.1",
    "esbuild-plugin-solid": "^0.6.0",
    "fast-xml-parser": "^5.5.12",
    "idb-keyval": "^6.2.2",
    "kuromoji": "^0.1.2",
    "lenis": "^1.3.21",
    "lucide-solid": "^0.577.0",
    "lz-string": "^1.5.0",
    "nanostores": "^1.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "solid-js": "^1.9.12",
    "solid-sonner": "^0.2.8",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@spicemod/creator": "^0.0.35",
    "@types/bun": "^1.3.12",
    "@types/gsap": "^3.0.0",
    "@types/kuromoji": "^0.1.3",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "arabic-transliteration": "workspace:*",
    "armenian-transliteration": "workspace:*",
    "cyrillic-romanization": "^1.1.8",
    "esbuild": "^0.27.7",
    "gothic-transliteration": "workspace:*",
    "greek-transliteration": "^2.0.0",
    "happy-dom": "^20.8.9",
    "hebrew-transliteration": "workspace:*",
    "kuroshiro": "^1.2.0",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.60.0",
    "persian-transliteration": "workspace:*",
    "pinyin": "^4.0.0",
    "urdu-transliteration": "workspace:*",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4",
    "vue": "^3.5.32"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
